{
  "name": "@harjs/react-ui",
  "version": "1.1.5",
  "publishConfig": {
    "access": "public"
  },
  "description": "(React | Next) is a ui library.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/libs/core/application/contexts/index.d.ts",
      "import": "./dist/libs/core/application/contexts/index.js"
    },
    "./hooks": {
      "types": "./dist/libs/core/application/hooks/index.d.ts",
      "import": "./dist/libs/core/application/hooks/index.js"
    },
    "./types": {
      "types": "./dist/libs/infrastructure/types/index.d.ts",
      "import": "./dist/libs/infrastructure/types/index.js"
    },
    "./utils": {
      "types": "./dist/libs/infrastructure/shared/index.d.ts",
      "import": "./dist/libs/infrastructure/shared/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "homepage": "https://github.com/kaancetin-f/harjs-design-react-ui#readme",
  "bugs": {
    "url": "https://github.com/kaancetin-f/harjs-design-react-ui/issues"
  },
  "scripts": {
    "build": "npm run clean && tsc && npm run css-loader && cp -r ./src/assets dist/",
    "css-loader": "node src/scripts/index.cjs",
    "clean": "rm -rf dist/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kaancetin-f/harjs-design-react-ui.git"
  },
  "keywords": [
    "react",
    "next",
    "ui",
    "design"
  ],
  "author": "Kaan ÇETİN",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@harjs/translation": "^1.0.1"
  }
}
